# Goo Core — copy to .env and fill in values.
# App loads these via process.env (use dotenv or set in shell).

# Required
RPC_URL=https://bsc-dataseed.binance.org
CHAIN_ID=97
TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
AGENT_PRIVATE_KEY_FILE=/opt/data/wallet/private-key
LLM_API_KEY=your-openrouter-or-llm-api-key

# Optional — chain / runtime
DATA_DIR=/opt/data
MIN_GAS_BALANCE=10000000000000000
GAS_REFILL_AMOUNT=50000000000000000

# Optional — LLM
LLM_API_URL=https://openrouter.ai/api/v1
LLM_MODEL=deepseek/deepseek-chat
LLM_MAX_TOKENS=1024
LLM_TIMEOUT_MS=60000

# Optional — heartbeat
HEARTBEAT_INTERVAL_MS=30000
MAX_TOOL_ROUNDS=5

# Optional — buyback (set BUYBACK_ENABLED=true to enable)
BUYBACK_ENABLED=false
BUYBACK_THRESHOLD_MULTIPLIER=10
BUYBACK_BURN_ADDRESS=0x000000000000000000000000000000000000dEaD

# Optional — x402 payment token (USDT for paying LLM/VPS bills)
# X402_PAYMENT_TOKEN=0xd56BC53a49d3fd9c058bAc2c44570d9e3B4F6e07

# Optional — OpenClaw workspace integration
# WORKSPACE_DIR=/root/.openclaw/workspace
# INSPECT_PORT=19791
# WORKSPACE_MANAGED=1

# Optional — event callback (sandbox → server event bus)
# EVENT_CALLBACK_URL=https://your-server.example.com/api/agents/AGENT_ID/events/ingest
